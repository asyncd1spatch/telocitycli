{
  "name": "telocitycli",
  "version": "0.0.33",
  "author": "asyncd1spatch",
  "description": "cli scaffold",
  "type": "module",
  "private": true,
  "files": [
    "start.ts",
    "src/",
    "data/"
  ],
  "bin": {
    "telocitycli": "./start.ts"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./core": {
      "import": "./src/libs/core/index.ts"
    },
    "./types": {
      "import": "./src/libs/types/index.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prepack": "bun run test",
    "pretest": "bun install && bun typecheck && bun lint",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "format": "dprint fmt",
    "test": "bun test --concurrent",
    "start": "bun ./start.ts",
    "build:bin": "bun build.bin.js",
    "hydrate": "bash ./scripts/hydratefromtelocity.sh"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20251017.1",
    "bun-types": "1.3.0",
    "dprint": "0.50.2",
    "oxlint": "1.23.0"
  }
}
